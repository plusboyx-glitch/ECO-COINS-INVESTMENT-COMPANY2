<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content="EcoVest Capital - Secure global investment platform for cryptocurrency, gold, oil, and real estate">
  <meta name="theme-color" content="#00ff88">
  <title>EcoVest Capital - Global Investment Platform</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    :root {
      --primary: #00ff88;
      --primary-dark: #00cc6f;
      --secondary: #0066ff;
      --dark: #0b0f14;
      --darker: #0f2027;
      --card-bg: #111;
      --text: #fff;
      --text-muted: #aaa;
      --transition: 0.3s ease;
      --shadow: 0 10px 30px rgba(0, 255, 136, 0.15);
    }

    /* Animations */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    @keyframes slideInLeft {
      from {
        opacity: 0;
        transform: translateX(-50px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes slideInRight {
      from {
        opacity: 0;
        transform: translateX(50px);
      }
      to {
        opacity: 1;
        transform: translateX(0);
      }
    }

    @keyframes glow {
      0%, 100% {
        box-shadow: 0 0 10px rgba(0, 255, 136, 0.3);
      }
      50% {
        box-shadow: 0 0 20px rgba(0, 255, 136, 0.6);
      }
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0);
      }
      50% {
        transform: translateY(-10px);
      }
    }

    @keyframes shimmer {
      0% {
        background-position: -1000px 0;
      }
      100% {
        background-position: 1000px 0;
      }
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
      background: linear-gradient(135deg, var(--dark), var(--darker));
      color: var(--text);
      line-height: 1.6;
      overflow-x: hidden;
      scroll-behavior: smooth;
    }

    /* Header & Navigation */
    header {
      background: linear-gradient(rgba(0, 0, 0, 0.95), rgba(15, 32, 39, 0.8));
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
      position: sticky;
      top: 0;
      z-index: 1000;
      box-shadow: 0 4px 20px rgba(0, 255, 136, 0.1);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(0, 255, 136, 0.2);
    }

    header h1 {
      color: var(--primary);
      font-size: 1.8rem;
      font-weight: 700;
      animation: slideInLeft 0.6s ease;
      letter-spacing: 1px;
    }

    nav {
      display: flex;
      gap: 2rem;
      animation: slideInRight 0.6s ease;
    }

    nav a {
      color: var(--text);
      text-decoration: none;
      font-weight: 600;
      transition: all var(--transition);
      padding: 0.5rem 1rem;
      position: relative;
      border-radius: 0.3rem;
    }

    nav a::before {
      content: '';
      position: absolute;
      bottom: 0;
      left: 0;
      width: 0;
      height: 2px;
      background: var(--primary);
      transition: width var(--transition);
    }

    nav a:hover {
      color: var(--primary);
    }

    nav a:hover::before {
      width: 100%;
    }

    /* Mobile Menu Button */
    .menu-toggle {
      display: none;
      background: none;
      border: none;
      color: var(--primary);
      font-size: 1.5rem;
      cursor: pointer;
      transition: transform var(--transition);
    }

    .menu-toggle:hover {
      transform: scale(1.2);
    }

    @media (max-width: 768px) {
      nav {
        display: none;
        position: absolute;
        top: 100%;
        left: 0;
        right: 0;
        flex-direction: column;
        background: rgba(0, 0, 0, 0.98);
        padding: 1rem;
        gap: 0;
        border-bottom: 2px solid var(--primary);
      }

      nav.active {
        display: flex;
      }

      .menu-toggle {
        display: block;
      }

      nav a {
        padding: 1rem;
        border-bottom: 1px solid rgba(0, 255, 136, 0.1);
      }
    }

    /* Hero Section */
    .hero {
      text-align: center;
      padding: 10rem 2rem;
      background: linear-gradient(135deg, rgba(0, 0, 0, 0.7) 0%, rgba(15, 32, 39, 0.7) 50%, rgba(0, 102, 255, 0.1) 100%), 
                  url('https://images.unsplash.com/photo-1640161704729-cbe966a08476') center/cover no-repeat;
      position: relative;
      overflow: hidden;
      min-height: 600px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
    }

    .hero::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: 
        radial-gradient(circle at 20% 50%, rgba(0, 255, 136, 0.1) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(0, 102, 255, 0.1) 0%, transparent 50%);
      pointer-events: none;
    }

    .hero h2 {
      font-size: clamp(2rem, 6vw, 4rem);
      margin-bottom: 1.5rem;
      font-weight: 800;
      color: var(--primary);
      text-shadow: 0 4px 20px rgba(0, 255, 136, 0.3);
      animation: fadeInUp 0.8s ease;
      position: relative;
      z-index: 1;
      letter-spacing: 1px;
    }

    .hero p {
      font-size: 1.3rem;
      color: #ccc;
      margin-bottom: 2.5rem;
      text-shadow: 0 2px 10px rgba(0, 0, 0, 0.5);
      animation: fadeInUp 0.8s ease 0.2s backwards;
      position: relative;
      z-index: 1;
    }

    /* Buttons */
    .btn {
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      color: var(--dark);
      padding: 0.9rem 2.5rem;
      border: none;
      cursor: pointer;
      border-radius: 0.6rem;
      font-weight: 700;
      font-size: 1rem;
      transition: all var(--transition);
      text-decoration: none;
      display: inline-block;
      position: relative;
      z-index: 1;
      box-shadow: 0 4px 15px rgba(0, 255, 136, 0.2);
      overflow: hidden;
      animation: fadeInUp 0.8s ease 0.4s backwards;
    }

    .btn::before {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: rgba(255, 255, 255, 0.2);
      transition: left 0.5s ease;
    }

    .btn:hover::before {
      left: 100%;
    }

    .btn:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 25px rgba(0, 255, 136, 0.4);
    }

    .btn:active {
      transform: translateY(-2px);
    }

    .btn-secondary {
      background: linear-gradient(135deg, transparent, transparent);
      color: var(--primary);
      border: 2px solid var(--primary);
      box-shadow: inset 0 0 20px rgba(0, 255, 136, 0.1);
    }

    .btn-secondary:hover {
      background: linear-gradient(135deg, var(--primary), var(--primary-dark));
      color: var(--dark);
      box-shadow: 0 8px 25px rgba(0, 255, 136, 0.4);
    }

    /* Sections */
    .section {
      padding: 5rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
      animation: fadeInUp 0.8s ease;
    }

    .section h2 {
      font-size: clamp(1.8rem, 5vw, 2.8rem);
      margin-bottom: 1rem;
      text-align: center;
      font-weight: 800;
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      letter-spacing: 1px;
    }

    .section::after {
      content: '';
      display: block;
      width: 100px;
      height: 4px;
      background: linear-gradient(90deg, var(--primary), var(--secondary));
      margin: 1.5rem auto 3rem;
      border-radius: 2px;
    }

    /* Cards Grid */
    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 2.5rem;
      margin-top: 3rem;
    }

    .card {
      background: linear-gradient(135deg, rgba(17, 17, 17, 0.8), rgba(17, 17, 17, 0.4));
      border-radius: 1.2rem;
      overflow: hidden;
      transition: all var(--transition);
      box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
      border: 1px solid rgba(0, 255, 136, 0.15);
      backdrop-filter: blur(10px);
      animation: fadeInUp 0.8s ease;
    }

    .card:nth-child(2) {
      animation-delay: 0.1s;
    }

    .card:nth-child(3) {
      animation-delay: 0.2s;
    }

    .card:nth-child(4) {
      animation-delay: 0.3s;
    }

    .card:nth-child(5) {
      animation-delay: 0.4s;
    }

    .card:hover {
      transform: translateY(-16px) scale(1.02);
      box-shadow: var(--shadow), 0 20px 50px rgba(0, 255, 136, 0.2);
      border-color: rgba(0, 255, 136, 0.6);
      background: linear-gradient(135deg, rgba(17, 17, 17, 1), rgba(0, 102, 255, 0.1));
    }

    /* Image Container */
    .card-image-wrapper {
      position: relative;
      overflow: hidden;
      height: 260px;
      background: linear-gradient(135deg, #1a3a3a, #0a1a1a);
    }

    .card-image-wrapper::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(135deg, transparent 0%, rgba(0, 255, 136, 0.2) 100%);
      z-index: 1;
      pointer-events: none;
    }

    .card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
      filter: brightness(0.85) contrast(1.1);
    }

    .card:hover img {
      transform: scale(1.2) rotate(2deg);
      filter: brightness(1.15) saturate(1.3) contrast(1.2);
    }

    .card-content {
      padding: 2rem;
      position: relative;
      z-index: 2;
    }

    .card h3 {
      font-size: 1.4rem;
      margin-bottom: 0.8rem;
      color: var(--primary);
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    .card p {
      color: var(--text-muted);
      font-size: 0.95rem;
      line-height: 1.8;
    }

    /* Info Box */
    .info-box {
      background: linear-gradient(135deg, rgba(0, 255, 136, 0.08), rgba(0, 102, 255, 0.05));
      border-left: 5px solid var(--primary);
      padding: 2.5rem;
      border-radius: 0.8rem;
      margin: 2.5rem auto;
      max-width: 800px;
      box-shadow: 0 8px 30px rgba(0, 255, 136, 0.12);
      backdrop-filter: blur(10px);
      border-top: 1px solid rgba(0, 255, 136, 0.2);
      animation: fadeInUp 0.8s ease;
    }

    .info-box h3 {
      color: var(--primary);
      margin-bottom: 1.2rem;
      font-size: 1.6rem;
      font-weight: 700;
      letter-spacing: 0.5px;
    }

    .info-box p {
      color: #bbb;
      line-height: 1.8;
      margin-bottom: 1rem;
    }

    .info-box ul {
      list-style: none;
      padding-left: 0;
    }

    .info-box li {
      padding: 0.8rem 0;
      padding-left: 2rem;
      position: relative;
      color: #aaa;
      transition: all var(--transition);
      font-weight: 500;
    }

    .info-box li:hover {
      color: var(--text);
      padding-left: 2.3rem;
    }

    .info-box li:before {
      content: "✓";
      position: absolute;
      left: 0;
      color: var(--primary);
      font-weight: bold;
      font-size: 1.3rem;
      animation: float 2s ease-in-out infinite;
    }

    /* Crypto Gallery */
    .crypto-gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 3rem;
      margin-top: 3.5rem;
      justify-items: center;
    }

    .crypto-item {
      position: relative;
      width: 160px;
      height: 160px;
      display: flex;
      align-items: center;
      justify-content: center;
      animation: fadeInUp 0.8s ease;
    }

    .crypto-item:nth-child(1) { animation-delay: 0.1s; }
    .crypto-item:nth-child(2) { animation-delay: 0.2s; }
    .crypto-item:nth-child(3) { animation-delay: 0.3s; }
    .crypto-item:nth-child(4) { animation-delay: 0.4s; }

    /* Glow background */
    .crypto-item::before {
      content: '';
      position: absolute;
      width: 140%;
      height: 140%;
      background: radial-gradient(circle, rgba(0, 255, 136, 0.15) 0%, transparent 70%);
      border-radius: 50%;
      z-index: 0;
      transition: all 0.5s ease;
    }

    .crypto-item:hover::before {
      background: radial-gradient(circle, rgba(0, 255, 136, 0.35) 0%, rgba(0, 102, 255, 0.1) 70%);
      transform: scale(1.3);
    }

    .crypto-gallery img {
      width: 130px;
      height: 130px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--card-bg), rgba(17, 17, 17, 0.5));
      padding: 0.75rem;
      transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
      border: 3px solid rgba(0, 255, 136, 0.25);
      position: relative;
      z-index: 1;
      box-shadow: 0 0 30px rgba(0, 0, 0, 0.5);
    }

    .crypto-gallery img:hover {
      transform: scale(1.2) rotateZ(15deg);
      border-color: var(--primary);
      box-shadow: 0 0 40px rgba(0, 255, 136, 0.6), 0 0 80px rgba(0, 255, 136, 0.2), inset 0 0 20px rgba(0, 255, 136, 0.1);
      filter: drop-shadow(0 0 15px rgba(0, 255, 136, 0.5));
    }

    /* Disclaimer Section */
    .disclaimer {
      background: linear-gradient(135deg, rgba(255, 193, 7, 0.08), rgba(255, 100, 0, 0.05));
      border: 2px solid rgba(255, 193, 7, 0.35);
    }

    .disclaimer h2 {
      background: linear-gradient(135deg, #ffc107, #ff9800);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    /* Footer */
    footer {
      text-align: center;
      padding: 3rem 2rem;
      background: linear-gradient(135deg, rgba(0, 0, 0, 0.95), rgba(15, 32, 39, 0.8));
      margin-top: 4rem;
      border-top: 2px solid rgba(0, 255, 136, 0.2);
      color: var(--text-muted);
    }

    footer p {
      margin: 0.8rem 0;
      font-weight: 500;
    }

    footer a {
      color: var(--primary);
      text-decoration: none;
      transition: all var(--transition);
      font-weight: 600;
    }

    footer a:hover {
      color: var(--text);
      text-decoration: underline;
    }

    /* Accessibility */
    :focus {
      outline: 2px solid var(--primary);
      outline-offset: 3px;
    }

    @media (prefers-reduced-motion: reduce) {
      * {
        animation: none !important;
        transition: none !important;
      }
    }

    /* Responsive */
    @media (max-width: 768px) {
      header {
        padding: 1rem;
      }

      .hero {
        padding: 6rem 1.5rem;
        min-height: 450px;
      }

      .hero h2 {
        font-size: 1.8rem;
      }

      .section {
        padding: 3rem 1.5rem;
      }

      .cards {
        gap: 1.5rem;
      }

      .card-image-wrapper {
        height: 200px;
      }

      .crypto-gallery {
        grid-template-columns: repeat(2, 1fr);
        gap: 2rem;
      }

      .crypto-item {
        width: 120px;
        height: 120px;
      }

      .crypto-gallery img {
        width: 100px;
        height: 100px;
      }
    }

    /* Light Mode Support */
    @media (prefers-color-scheme: light) {
      :root {
        --dark: #f5f5f5;
        --darker: #e8e8e8;
        --card-bg: #fff;
        --text: #333;
        --text-muted: #666;
      }

      body {
        background: linear-gradient(135deg, #f5f5f5, #e8e8e8);
      }

      header {
        background: linear-gradient(rgba(255, 255, 255, 0.95), rgba(248, 248, 248, 0.9));
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      }

      .card {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(248, 248, 248, 0.5));
        border-color: rgba(0, 255, 136, 0.2);
      }

      .info-box {
        background: linear-gradient(135deg, rgba(0, 255, 136, 0.1), rgba(0, 102, 255, 0.08));
        border-color: rgba(0, 255, 136, 0.4);
      }

      footer {
        background: linear-gradient(135deg, rgba(255, 255, 255, 0.95), rgba(248, 248, 248, 0.9));
        border-top-color: rgba(0, 255, 136, 0.3);
      }
    }
  </style>
</head>
<body>
  <!-- Header -->
  <header>
    <h1>EcoVest Capital</h1>
    <button class="menu-toggle" aria-label="Toggle navigation menu" onclick="toggleMenu()">☰</button>
    <nav id="nav-menu">
      <a href="#home">Home</a>
      <a href="#invest">Invest</a>
      <a href="#crypto">Crypto</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <!-- Main Content -->
  <main>
    <!-- Hero Section -->
    <section class="hero" id="home">
      <h2>Global Investment Platform for Everyone</h2>
      <p>Invest Anytime, Anywhere in Crypto, Gold, Oil & Real Estate</p>
      <button class="btn" onclick="scrollToSection('invest')">Start Investing</button>
    </section>

    <!-- Worldwide Access Section -->
    <section class="section">
      <h2>🌍 Worldwide Access</h2>
      <div class="info-box">
        <h3>Available Globally</h3>
        <p>EcoVest Capital is built for users all around the world. Anyone can join, invest, and grow wealth regardless of location.</p>
        <ul>
          <li>Multi-country access</li>
          <li>Secure system</li>
          <li>Fast transactions</li>
          <li>24/7 availability</li>
        </ul>
      </div>
    </section>

    <!-- Investment Opportunities Section -->
    <section class="section" id="invest">
      <h2>Investment Opportunities</h2>
      <div class="cards">
        <article class="card">
          <div class="card-image-wrapper">
            <img src="https://images.unsplash.com/photo-1621761191319-c6fb62004040?w=500&h=300&fit=crop" alt="Bitcoin and cryptocurrency coins" loading="lazy">
          </div>
          <div class="card-content">
            <h3>Crypto Currency</h3>
            <p>High risk, high return global market with unlimited potential</p>
          </div>
        </article>

        <article class="card">
          <div class="card-image-wrapper">
            <img src="https://images.unsplash.com/photo-1610375461246-83df859d849d?w=500&h=300&fit=crop" alt="Gold bars and coins" loading="lazy">
          </div>
          <div class="card-content">
            <h3>Gold</h3>
            <p>Safe and stable long-term investment for wealth preservation</p>
          </div>
        </article>

        <article class="card">
          <div class="card-image-wrapper">
            <img src="https://images.unsplash.com/photo-1611078489935-0cb964de46d6?w=500&h=300&fit=crop" alt="Silver precious metal" loading="lazy">
          </div>
          <div class="card-content">
            <h3>Silver</h3>
            <p>Balanced growth and stability with industrial demand</p>
          </div>
        </article>

        <article class="card">
          <div class="card-image-wrapper">
            <img src="https://images.unsplash.com/photo-1581093588401-22b08f9d0d3c?w=500&h=300&fit=crop" alt="Crude oil extraction" loading="lazy">
          </div>
          <div class="card-content">
            <h3>Crude Oil</h3>
            <p>Market-driven global commodity with strong growth</p>
          </div>
        </article>

        <article class="card">
          <div class="card-image-wrapper">
            <img src="https://images.unsplash.com/photo-1560518883-ce09059eeffa?w=500&h=300&fit=crop" alt="Modern residential buildings" loading="lazy">
          </div>
          <div class="card-content">
            <h3>Real Estate</h3>
            <p>Long-term wealth building assets with steady returns</p>
          </div>
        </article>
      </div>
    </section>

    <!-- Cryptocurrencies Section -->
    <section class="section" id="crypto">
      <h2>Top Cryptocurrencies</h2>
      <p style="text-align: center; color: var(--text-muted); margin-bottom: 2rem; font-weight: 500;">Invest in the world's leading digital assets</p>
      <div class="crypto-gallery">
        <div class="crypto-item">
          <img src="https://cryptologos.cc/logos/bitcoin-btc-logo.png" alt="Bitcoin logo" loading="lazy">
        </div>
        <div class="crypto-item">
          <img src="https://cryptologos.cc/logos/ethereum-eth-logo.png" alt="Ethereum logo" loading="lazy">
        </div>
        <div class="crypto-item">
          <img src="https://cryptologos.cc/logos/tether-usdt-logo.png" alt="Tether USDT logo" loading="lazy">
        </div>
        <div class="crypto-item">
          <img src="https://cryptologos.cc/logos/binance-coin-bnb-logo.png" alt="Binance Coin BNB logo" loading="lazy">
        </div>
      </div>
    </section>

    <!-- Backend Integration Section -->
    <section class="section">
      <h2>⚙️ Advanced Features</h2>
      <div class="info-box">
        <h3>Backend Integration (API Ready)</h3>
        <p>This platform is designed to work with a secure backend system that powers real-time investment tracking and portfolio management.</p>
        <ul>
          <li>User Login & Logout System</li>
          <li>Investment Endpoint (/invest)</li>
          <li>Crypto Price API (Bitcoin live price)</li>
          <li>Database for storing users</li>
          <li>Secure authentication system</li>
        </ul>
      </div>
    </section>

    <!-- Contact Section -->
    <section class="section" id="contact">
      <h2>Contact Us</h2>
      <div class="info-box">
        <h3>Get in Touch</h3>
        <p><strong>Email:</strong> <a href="mailto:support@ecovest.com" style="color: var(--primary); text-decoration: none; font-weight: 600;">support@ecovest.com</a></p>
        <p><strong>Phone:</strong> <a href="tel:+447523181942" style="color: var(--primary); text-decoration: none; font-weight: 600;">+44 752 318 1942</a></p>
        <p style="margin-top: 1.5rem;">Available worldwide 🌍</p>
      </div>
    </section>

    <!-- Disclaimer Section -->
    <section class="section disclaimer">
      <h2>⚠️ Important Disclaimer</h2>
      <div class="info-box" style="border-color: rgba(255, 193, 7, 0.5); background: linear-gradient(135deg, rgba(255, 193, 7, 0.08), rgba(255, 100, 0, 0.05));">
        <h3 style="color: #ffc107; font-weight: 700;">Risk Warning</h3>
        <p>EcoVest Capital provides access to different asset classes including cryptocurrency, commodities, and real estate. Please read carefully:</p>
